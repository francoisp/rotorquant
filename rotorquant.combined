    print(f"  {'─'*6}  {'─'*8}  {'─'*14}  {'─'*14}  {'─'*10}  {'─'*10}")

    for d in [64, 128, 256, 512]:
        rq = RotorQuantMSE(d, bits, seed=42, device=device)
        packed_rotors = pack_rotors_for_triton(rq.rotors).to(device)
        c_s = None
        c_v = getattr(rq, 'centroids_vector')
        c_b = None
